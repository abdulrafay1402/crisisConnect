NODE_ENV=development
PORT=5000

# Database settings
# Option A (recommended portability): SQL Authentication
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=DisasterManagement
DB_USER=sa
DB_PASSWORD=your_password_here

# Option B (Windows integrated auth): keep DB_USE_MSNODESQLV8=true and leave DB_USER/DB_PASSWORD empty
DB_USE_MSNODESQLV8=true
DB_CONNECTION_STRING=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_CONNECTION_TIMEOUT_MS=15000
DB_REQUEST_TIMEOUT_MS=15000
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_IDLE_TIMEOUT_MS=30000

JWT_SECRET=your_very_long_random_secret_key_here_change_this_in_production
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=200
LOG_LEVEL=debug
